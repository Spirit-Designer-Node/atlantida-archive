/* --------------------------- ARCHIVE FIND ----------------------------- */
// [DETECT]    Volumes := 13
// [MATERIAL]  Binding := UNIDENTIFIED
//             No equivalent material in Ragnatida.
//             No equivalent material in any known archive.
// [DETECT]    Ink := UNIDENTIFIED
